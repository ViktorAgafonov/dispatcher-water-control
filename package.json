{
  "name": "pulsar-monitor",
  "version": "1.1.0",
  "description": "Программный комплекс оперативного контроля и диспетчеризации водоснабжения производственных объектов",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "pack": "electron-packager . \"Диспетчер Водоснабжения\" --platform=win32 --arch=x64 --out=dist --overwrite --app-version=1.1.0 --asar --prune=true --ignore=\"^/dist($|/)\" --ignore=\"^/scripts($|/)\" --ignore=\"^/\\.git($|/)\" --ignore=\"^/build\\.(bat|ps1)$\" --ignore=\"^/device\\.log$\" --ignore=\"^/protokol_pulsar_m\\.pdf$\" --ignore=\"^/README\\.md$\"",
    "build": "npm run clean && npm run pack && node scripts/post-build.js",
    "build:zip": "npm run build && node scripts/build-zip.js"
  },
  "author": "Агафонов В.В.",
  "license": "MIT",
  "homepage": "https://github.com/ViktorAgafonov/dispatcher-water-control",
  "repository": {
    "type": "git",
    "url": "https://github.com/ViktorAgafonov/dispatcher-water-control.git"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-packager": "^17.1.2"
  }
}
